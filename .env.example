# Copy this file to `.env` before running `docker compose`.
# Used by the repo-root `docker-compose.yml` for local container values.
# For the native server runtime (`DATABASE_URL`, etc.), use `server/.env.example`.

ADMIN_CODE=choose-a-local-admin-code
COOKIE_SECRET=choose-a-long-random-cookie-secret
POSTGRES_PASSWORD=choose-a-local-postgres-password
