# Copy this file to `.env` and set your own values before starting.
# Loaded automatically by the native server runtime in local development.
# For Docker Compose values like `POSTGRES_PASSWORD`, use the repo-root `.env.example`.

# Admin login code for /admin. Required in every environment.
ADMIN_CODE=replace-with-your-admin-code

# Used to sign session cookies. Required in production; set it explicitly in dev too.
COOKIE_SECRET=replace-with-a-long-random-secret

# PostgreSQL connection string for the application data store.
# If you use `docker compose up -d postgres`, match docker-compose.yml:
# host `127.0.0.1`, user `whack_a_hack`, db `whack_a_hack`,
# and the `POSTGRES_PASSWORD` value from the repo-root `.env`.
DATABASE_URL=postgresql://whack_a_hack:replace-with-the-postgres-password-from-repo-root-dot-env@127.0.0.1:5432/whack_a_hack

# Set to `disable` for local dev and `require` for Azure PostgreSQL.
DATABASE_SSL_MODE=disable

# Optional override for Secure cookies. Leave unset in production so HTTPS-only cookies stay enabled.
# COOKIE_SECURE=false
